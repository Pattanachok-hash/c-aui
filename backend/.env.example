# Copy this file to `.env` and fill in real values.
# DO NOT commit `.env` to git.

# ── Supabase (same project as warehouse-scanner) ────────────────────────
# Find under Project Settings → API
SUPABASE_URL=https://aprmihzsessyptzqgdvs.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ── Resend (transactional email) ────────────────────────────────────────
# Use the same key as warehouse-scanner / transport-dashboard
RESEND_API_KEY=
EMAIL_FROM=noreply@c-aui.com

# ── Portal developer (single portal manager who approves signups) ───────
DEVELOPER_EMAIL=pattanachok_msn@hotmail.com

# ── Public URL of the portal frontend (used in email links) ─────────────
# For local testing keep as localhost; production = https://c-aui.com
PORTAL_FRONTEND_URL=http://localhost:5500

# ── CORS allowed origins (regex) ────────────────────────────────────────
# Default allows any *.c-aui.com — add localhost during dev
CORS_ALLOW_ORIGIN_REGEX=^(http://localhost:\d+|https?://(.*\.)?c-aui\.com)$
